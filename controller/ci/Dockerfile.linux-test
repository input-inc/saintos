# Linux toolchain for running the controller's Rust test suite —
# including the `#[cfg(target_os = "linux")]` Steam Deck HID parser tests
# that don't compile on macOS/Windows. Used by:
#   - controller/ci/run-linux-tests.sh  (local dev on any host w/ Docker)
#   - .github/workflows/controller-tests.yml  (CI)
#
# Deps mirror the Tauri 2 Linux link-time set in controller/appimage/
# Dockerfile, minus the AppImage bundling tools (irrelevant to tests).
# libudev-dev is what hidapi/evdev link against. No nodejs: `cargo test`
# runs build.rs/tauri-build but NOT the beforeBuildCommand, so it only
# needs frontendDist to exist — run-linux-tests.sh stubs it.
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH=/root/.cargo/bin:$PATH

# Retry loops absorb the transient apt/DNS blips that otherwise kill a
# from-scratch image build.
RUN echo 'Acquire::Retries "10";' > /etc/apt/apt.conf.d/80retries && \
    for i in 1 2 3 4 5; do \
      apt-get update && apt-get install -y --no-install-recommends \
        libwebkit2gtk-4.1-dev libsoup-3.0-dev libgtk-3-dev librsvg2-dev \
        libssl-dev libudev-dev pkg-config build-essential file \
        ca-certificates curl git && break || { echo "apt attempt $i failed; sleeping"; sleep 8; }; \
    done && rm -rf /var/lib/apt/lists/*

# Current stable Rust — Ubuntu's rustc is too old to parse the v4 Cargo.lock.
RUN for i in 1 2 3 4 5; do \
      curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs -o /tmp/rustup.sh && break || sleep 8; \
    done && \
    sh /tmp/rustup.sh -y --default-toolchain stable --profile minimal --no-modify-path && \
    rm -f /tmp/rustup.sh

WORKDIR /work/controller/src-tauri
