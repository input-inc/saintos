# SAINT.OS Teensy 4.1 Node: teensy_smoke
# Auto-generated by node_manager.py

$machine_name="teensy_smoke"

path add @/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/teensy41/simulation/renode_teensy41

# Include peripheral C# definitions and create machine
include @/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/teensy41/simulation/renode_teensy41/cores/initialize_peripherals.resc

# Load Teensy 4.1 platform (inherits Renode's imxrt1064.repl + adds the
# SAINT-specific external_flash, udp_bridge, and persistent_storage).
machine LoadPlatformDescription @/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/teensy41/simulation/renode_teensy41/boards/teensy41.repl

# Configure peripherals for this specific node
sysbus.persistent_storage StoragePath "/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/simulation/teensy41_storage"
sysbus.persistent_storage NodeId "teensy_smoke"
sysbus.udp_bridge LocalPort 9991

# Load firmware into the external-flash region (0x60000000 — XIP base).
sysbus LoadELF @/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/teensy41/build/simulation/firmware.elf

# Point the Cortex-M's vector table at the XIP base so the CPU reads its
# reset SP / reset handler from the firmware ELF instead of the empty
# ITCM at 0x00000000 (where VTOR defaults). The Teensy bootloader does
# this on real silicon by copying VT to ITCM + writing VTOR; bypassing
# the bootloader, we just point VTOR at flash directly.
sysbus.cpu VectorTableOffset 0x60000000

# Capture firmware UART output to a dedicated file. The firmware redirects
# `Serial` → `Serial1` under SIMULATION (see firmware/teensy41/include/
# platform.h); Serial1 on Teensy 4.1 = LPUART6. Renode's NXP_LPUART model
# at 0x40198000 maps to `lpuart6` in the imxrt1064 repl. CreateFileBackend
# mirrors that peripheral's TX bytes to a text file the harness can tail.
sysbus.lpuart6 CreateFileBackend @/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/simulation/logs/teensy_smoke.uart.log true
showAnalyzer sysbus.lpuart6

echo "SAINT.OS Teensy 4.1 Node: teensy_smoke"
echo "  UDP Port: 9991"
echo "  Storage: /Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/simulation/teensy41_storage/teensy_smoke.bin"
echo "  UART log: /Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/simulation/logs/teensy_smoke.uart.log"

start
