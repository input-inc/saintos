# SAINT.OS RP2040 Node: rp2040_synctest
# Auto-generated by node_manager.py

$machine_name="rp2040_synctest"

path add @/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/rp2040/simulation/renode_rp2040

# Include peripheral C# definitions and create machine
include @/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/rp2040/simulation/renode_rp2040/cores/initialize_peripherals_simple.resc

# Load standard platform
machine LoadPlatformDescription @/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/rp2040/simulation/renode_rp2040/boards/adafruit_feather_rp2040.repl

# Configure peripherals for this specific node
sysbus.persistent_storage StoragePath "/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/simulation/rp2040_storage"
sysbus.persistent_storage NodeId "rp2040_synctest"
sysbus.udp_bridge LocalPort 9994

# Load bootrom and firmware
sysbus LoadELF @/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/rp2040/simulation/renode_rp2040/bootroms/rp2040/b2.elf
sysbus LoadELF @/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/rp2040/install/simulation/saint_node.elf

# Set vector table
sysbus.cpu0 VectorTableOffset 0x00000000
sysbus.cpu1 VectorTableOffset 0x00000000

# Keep cpu1 halted
cpu1 IsHalted true

# Reduce CPU translation block size to minimize dirty address accumulation
# (helps prevent memory exhaustion from frequent memory-mapped I/O)
cpu0 MaximumBlockSize 1

# Capture firmware UART output to a dedicated file. showAnalyzer alone
# only opens an analyzer window — in --disable-xwt --console headless
# mode that window doesn't exist, so previously the firmware's printf
# stream had nowhere to land and operators saw an empty log. The
# CreateFileBackend tap mirrors UART0 bytes to a text file alongside
# the Renode operational log; `node_manager.py logs <id>` (and the
# e2e test harness) reads this file for firmware boot markers.
sysbus.uart0 CreateFileBackend @/Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/simulation/logs/rp2040_synctest.uart.log true
showAnalyzer sysbus.uart0

# Log UART transactions at info level — adds peripheral-level
# diagnostics to the operational log too, separate from the firmware
# stdout stream captured above.
logLevel -1 sysbus.uart0

echo "SAINT.OS RP2040 Node: rp2040_synctest"
echo "  UDP Port: 9994"
echo "  Storage: /Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/simulation/rp2040_storage/rp2040_synctest.bin"
echo "  UART log: /Users/hackman/Projects/OpenSAINT/SaintOS/source/firmware/simulation/logs/rp2040_synctest.uart.log"

start
