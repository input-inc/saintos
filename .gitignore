# SAINT.OS .gitignore

# =============================================================================
# ROS2 / Colcon Build Directories
# =============================================================================
build/
install/
log/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# Firmware vendor libraries (submodules) are real source, not Python build dirs
!firmware/*/lib/
!firmware/*/lib/**
# CI installer payload is source, not a Python build dir
!.github/dist/
!.github/dist/**
# Web frontend's bundled JS libraries are checked-in source
!server/web/js/lib/
!server/web/js/lib/**

# Local-builder scratch dirs (scripts/build-local-dist.sh)
/_debs/
/_ros2/
/_ros2_src/
/_fw/
# Locally-built firmware artifacts staged into the dist tarball.
# The committed info.json files (manifests) ARE tracked, but the actual
# binaries are build outputs — let CI / local builds regenerate them.
# Host-runnable test binaries (built by firmware/rp2040/tests/run_tests.sh)
/firmware/rp2040/tests/test_fas100_parser
/firmware/rp2040/tests/test_roboclaw_driver
/firmware/rp2040/tests/*.dSYM/
/server/resources/firmware/rp2040/*.uf2
/server/resources/firmware/rp2040/*.elf
/server/resources/firmware/rp2040/*.bin
/server/resources/firmware/rp2040/generated/
/server/resources/firmware/teensy41/*.hex
/server/resources/firmware/rpi5/saint_firmware_rpi5_*-local.*.zip
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# =============================================================================
# Virtual Environments
# =============================================================================
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Conda
.conda/

# =============================================================================
# IDEs and Editors
# =============================================================================
# VSCode
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# =============================================================================
# OS Generated
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================================================================
# Firmware Build Outputs
# =============================================================================
firmware/current/
firmware/archive/
*.img
*.img.sha256

# =============================================================================
# Vendored SDKs (large, fetched separately)
# =============================================================================
# Pico SDK lives at the repo root so the RP2040 build can pick it up via
# PICO_SDK_PATH. It's not part of our source tree.
/pico-sdk/

# =============================================================================
# Logs and Databases
# =============================================================================
*.log
*.sqlite
*.db

# =============================================================================
# Secrets and Credentials
# =============================================================================
*.pem
*.key
*.crt
.env.local
.env.*.local
secrets.yaml
credentials.json

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
*.temp
*.bak
*.backup

# =============================================================================
# Controller Application (Tauri + Angular)
# =============================================================================
controller/node_modules/
controller/dist/
controller/src-tauri/target/
controller/src-tauri/gen/

# Built AppImage artifacts (output of controller/appimage/build-bundle.sh).
# These get staged into server/resources/firmware/controller/ at build
# time, then bundled into the dist tarball — they're regenerated from
# source on every build, no reason to keep them in git history.
server/resources/firmware/controller/*.AppImage

# =============================================================================
# Node.js / NPM
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================================================================
# Rust
# =============================================================================
target/
# Cargo.lock IS committed: the only Rust crate in this repo
# (controller/src-tauri/) is a binary, where checking in the lock file
# guarantees reproducible offline builds. Without it the Steam Deck
# (and any other build host) has to re-resolve the dependency graph
# from crates.io on every fresh checkout, which fails without network.
**/*.rs.bk
